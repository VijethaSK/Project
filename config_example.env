# Database Configuration
# Copy this file to .env and update with your database credentials

# Database Type: sqlite, mysql, postgresql, mssql
DATABASE_TYPE=sqlite

# MySQL/MariaDB Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=hotel_dbms

# PostgreSQL Configuration (same variables)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_NAME=hotel_dbms

# SQL Server Configuration (same variables)
# DB_HOST=localhost
# DB_PORT=1433
# DB_USER=sa
# DB_PASSWORD=your_password
# DB_NAME=hotel_dbms

